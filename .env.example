# ============================================================
# ChatVault AI - Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- WhatsApp Cloud API ---
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-app-secret

# --- WhatsApp Bridge ---
NEXT_PUBLIC_BRIDGE_URL=https://your-bridge-host.up.railway.app

# --- OpenRouter (LLM) ---
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Backblaze B2 (Object Storage) ---
B2_APPLICATION_KEY_ID=your-b2-key-id
B2_APPLICATION_KEY=your-b2-application-key
B2_BUCKET_NAME=chatvault-attachments
B2_BUCKET_ID=your-b2-bucket-id
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com

# --- Google Cloud Vision (Optional - for high-accuracy OCR) ---
GOOGLE_CLOUD_VISION_API_KEY=your-google-cloud-vision-key

# --- OpenAI Whisper (Optional - for voice transcription) ---
OPENAI_API_KEY=your-openai-api-key

# --- App Config ---
APP_URL=http://localhost:3000
WEBHOOK_URL=https://your-domain.vercel.app/api/webhook/whatsapp
NODE_ENV=development
